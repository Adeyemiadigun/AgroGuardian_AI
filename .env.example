# Database
MONGO_URI=mongodb://localhost:27017/agroguardian

# Redis (BullMQ)
# For local dev (recommended):
REDIS_URL=redis://localhost:6379
#
# Upstash example (TLS required):
# REDIS_URL=rediss://:YOUR_PASSWORD@moral-gobbler-95045.upstash.io:6379
# (Alternatively you can set REDIS_URL=moral-gobbler-95045.upstash.io:6379 and provide REDIS_PASSWORD)
#
# Optional split config:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Queue mode:
# - inline: no Redis/BullMQ (runs jobs in-process via setImmediate)
# - redis: use BullMQ + Redis
QUEUE_MODE=inline
# Force workers on/off (defaults to true when QUEUE_MODE=redis)
# RUN_WORKERS=true

# JWT
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here

# External APIs
WEATHER_API_KEY=your-openweather-api-key-here

# =============================================================================
# AI Configuration (OpenRouter)
# =============================================================================
# Get your free API key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Override default AI models
# NOTE: model availability changes frequently on OpenRouter. If you see 404 "No endpoints found",
# pick another model from https://openrouter.ai/models
#
# Vision model for image analysis (examples)
# AI_VISION_MODEL=openai/gpt-4o-mini
#
# Chat model for text conversations (examples)
# AI_CHAT_MODEL=openai/gpt-4o-mini
#
# Fallback model(s) if the primary model is unavailable/rate-limited.
# Comma-separated list, highest priority first.
# Recommended (good quality + a free last-resort):
# AI_FALLBACK_MODELS=google/gemini-2.5-flash,google/gemini-2.5-pro,google/gemma-3-12b-it:free
#
# Gemini 1.5 (sometimes has no active endpoints on OpenRouter; may 404):
# AI_FALLBACK_MODELS=google/gemini-flash-1.5,google/gemini-pro-1.5,google/gemma-3-12b-it:free
#
# Premium options (paid):
# AI_VISION_MODEL=openai/gpt-4o
# AI_CHAT_MODEL=openai/gpt-4o
# AI_VISION_MODEL=anthropic/claude-3.5-sonnet
# AI_CHAT_MODEL=anthropic/claude-3.5-sonnet

# App URL (used for OpenRouter analytics)
APP_URL=http://localhost:5000

# Optional: Enable OpenRouter reasoning mode for text chat (some models support this)
# AI_REASONING_ENABLED=true

# Optional: cap tokens to avoid OpenRouter 402 on expensive models
# AI_MAX_TOKENS=2048
# AI_CHAT_MAX_TOKENS=2048
# AI_VISION_MAX_TOKENS=2048

# Optional: retry settings for transient 429/503
# AI_RETRY_MAX=2
# AI_RETRY_BASE_MS=500

# Optional: when a provider is rate-limiting upstream, skip primary briefly
# AI_PRIMARY_COOLDOWN_MS=30000

# Optional: log token usage (including reasoning tokens when provided)
# AI_LOG_LLM_USAGE=true

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Weather Sync Configuration
# How often to update weather data for all active farms
# Options: 'hourly', '3-hourly', '6-hourly' (recommended), 'daily', 'twice-daily'
WEATHER_SYNC_INTERVAL=6-hourly

# Server
PORT=5000
NODE_ENV=development
