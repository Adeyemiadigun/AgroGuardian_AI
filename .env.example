# Database
MONGO_URI=mongodb://localhost:27017/agroguardian
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here

# External APIs
WEATHER_API_KEY=your-openweather-api-key-here

# =============================================================================
# AI Configuration (OpenRouter)
# =============================================================================
# Get your free API key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Override default AI models
# Vision model for image analysis (default: free Llama 3.2 90B Vision)
# AI_VISION_MODEL=meta-llama/llama-3.2-90b-vision-instruct:free
# 
# Chat model for text conversations (default: same as vision)
# AI_CHAT_MODEL=meta-llama/llama-3.2-90b-vision-instruct:free
#
# Premium options (paid):
# AI_VISION_MODEL=openai/gpt-4o
# AI_VISION_MODEL=anthropic/claude-3.5-sonnet
# AI_VISION_MODEL=google/gemini-pro-1.5

# App URL (used for OpenRouter analytics)
APP_URL=http://localhost:5000

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Weather Sync Configuration
# How often to update weather data for all active farms
# Options: 'hourly', '3-hourly', '6-hourly' (recommended), 'daily', 'twice-daily'
WEATHER_SYNC_INTERVAL=6-hourly

# Server
PORT=5000
NODE_ENV=development
